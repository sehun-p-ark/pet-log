<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="dev.dhkim.petlog.mappers.main.HospitalMapper">
    <insert id="insertHospital"
            parameterType="dev.dhkim.petlog.entities.main.HospitalEntity">
        INSERT INTO `petlog`.`hospital`(
            manage_no,
            name,
            address,
            lat,
            lng
        )
        VALUES (
                   #{manageNo},
                   #{name},
                   #{address},
                   #{lat},
                   #{lng}
               )
    </insert>
    <delete id="deleteAllHospitals">
        delete
        from `petlog`.`hospital`
    </delete>

    <!-- 1. 관리번호 중복 체크 -->
    <select id="existsByManageNo"
            parameterType="string"
            resultType="boolean">
        SELECT COUNT(*) > 0
        FROM `petlog`.`hospital`
        WHERE manage_no = #{manageNo}
    </select>

    <!-- 2. 위도/경도 NULL 또는 0 zeroLat / zeroLng = “쿼리 조건용 변수” 위도 경도에 0 이 들어간 경우 찾기 위해-->
    <select id="findInvalidCoords"
            resultType="dev.dhkim.petlog.entities.main.HospitalEntity">
        SELECT *
        FROM `petlog`.`hospital`
        WHERE lat IS NULL
           OR lng IS NULL
           OR lat = #{zeroLat}
           OR lng = #{zeroLng}
    </select>
    <!-- 3. 전체 조회 -->
    <select id="findAll"
            resultType="dev.dhkim.petlog.entities.main.HospitalEntity">
        SELECT *
        FROM `petlog`.`hospital`
    </select>

     <!--위도 경도 업데이트-->
    <update id="updateLatLng">
        update `petlog`.`hospital`
        set lat= #{lat},
            lng = #{lng}
        where id = #{id}
    </update>

</mapper>
