<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="dev.dhkim.petlog.mappers.shop.AdvertisementMapper">
    <select id="findAll" resultType="dev.dhkim.petlog.entities.shop.AdvertisementEntity">
        SELECT id, brand_name, image_url, content, sort_order
        FROM `petlog`.advertisement
        ORDER BY sort_order ASC
    </select>
</mapper>