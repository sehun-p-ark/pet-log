<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.dhkim.petlog.mappers.shop.SubCategoryMapper">

    <select id="selectByDisplayText" resultType="dev.dhkim.petlog.entities.shop.SubCategoryEntity">
        SELECT * FROM `petlog`.sub_category WHERE display_text = #{displayText}
    </select>

    <select id="selectByCategoryId" resultType="dev.dhkim.petlog.entities.shop.SubCategoryEntity">
        SELECT id, display_text AS displayText, category_id AS categoryId
        FROM `petlog`.sub_category
        WHERE category_id = #{categoryId}
        ORDER BY id
    </select>

    <select id="selectMainCategories" resultType="dev.dhkim.petlog.entities.shop.CategoryEntity">
        SELECT id, display_text AS displayText
        FROM `petlog`.category
        ORDER BY id
    </select>
</mapper>